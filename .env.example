# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
TZ=America/Bogota

# Database / Butterbase
DATABASE_URL=postgresql://solgreen:solgreen@localhost:5432/solgreen
BB_SECRET_KEY=managed-by-infisical

# Storage
OBJECT_STORAGE_BUCKET=solgreen-private

# AI providers. Values must come from Infisical, never Git.
MINIMAX_API_KEY=managed-by-infisical
DEEPSEEK_API_KEY=managed-by-infisical
AI_DEFAULT_PROVIDER=deepseek
AI_CRITICAL_REVIEW_PROVIDER=minimax

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=INFO
